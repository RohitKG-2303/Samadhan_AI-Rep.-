# Database
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=samadhan_user
DATABASE_PASSWORD=samadhan_password_123
DATABASE_NAME=samadhan_db

# MongoDB
MONGODB_URI=mongodb://mongo:27017/samadhan_learning

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password_123

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRATION=7d
JWT_REFRESH_EXPIRATION=30d

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4

# Pinecone
PINCECONE_API_KEY=your-pinecone-api-key
PINCECONE_ENVIRONMENT=us-west4-gcp
PINCECONE_INDEX=samadhan-documents

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=samadhan-documents

# ML Services
ML_SERVICE_URL=http://ml-services:5000

# Application
NODE_ENV=development
BACKEND_PORT=3001
FRONTEND_PORT=3000

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug
